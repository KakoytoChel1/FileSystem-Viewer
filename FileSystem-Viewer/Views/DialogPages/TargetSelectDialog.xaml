<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="FileSystem_Viewer.Views.DialogPages.TargetSelectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FileSystem_Viewer.Views.DialogPages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="DriveTemplate">
            <StackPanel Orientation="Horizontal">
                <Image Width="20" Source="../../Assets/disk.png"/>
                <TextBlock Margin="0,0,10,0"/>
                <TextBlock Text="{Binding Name}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <RadioButtons 
            Grid.Row="0"
            SelectedIndex="{x:Bind ViewModel.SelectedScanningTargetIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            
            <RadioButton Content="All drives"/>
            <RadioButton Content="Selected"/>
        </RadioButtons>

        <Button
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Height="30"
            Width="40"
            FontFamily="Segoe Fluent Icons"
            Content="&#xE895;"
            FontSize="14"
            ToolTipService.ToolTip="Refresh"
            Command="{x:Bind ViewModel.RefreshAvailableDrivesCollectionCommand}"/>

        <ListView 
            Grid.Row="1"
            x:Name="availableDrives" 
            SelectionMode="Multiple"
            SelectionChanged="availableDrives_SelectionChanged"
            ItemsSource="{x:Bind ViewModel.AllAvailableDrives}"
            ItemTemplate="{StaticResource DriveTemplate}">
        </ListView>
    </Grid>
</UserControl>
